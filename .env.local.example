# WordPress backend URL (without trailing slash)
# Used server-side only — never exposed to the browser
WORDPRESS_API_URL=http://localhost/your-wp-site

# Optional: used only if you call authenticated REST endpoints (e.g. /wp/v2/settings)
WORDPRESS_AUTH_USER=
WORDPRESS_AUTH_PASSWORD=

# Secret token for on-demand ISR revalidation webhook
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REVALIDATE_SECRET=change_me
